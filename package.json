{
  "name": "cursor-sdk-agent-examples",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript-first Cursor SDK agent examples with Python ports.",
  "type": "module",
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "tsc --noEmit --project tsconfig.eval.json && npm run build --workspaces",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:llm": "vitest run --config vitest.config.ts eval/tier1 eval/tier2 eval/parity/ts-python-trace.test.ts",
    "test:all": "npm run test && npm run test:llm",
    "eval:list": "tsx eval/cli.ts list",
    "eval:run": "tsx eval/cli.ts run",
    "migrate:python-ports": "npm --workspace @cursor-examples/migration-agent-ts run start --",
    "hello-world:ts": "npm --workspace @cursor-examples/hello-world-ts run start --",
    "tool-calling:ts": "npm --workspace @cursor-examples/tool-calling-agent-ts run start --",
    "accessibility-agent:ts": "npm --workspace @cursor-examples/accessibility-agent-ts run start --",
    "bugbot:validate": "npm --workspace @cursor-examples/bugbot-ts run start --",
    "security-reviewer:validate": "npm --workspace @cursor-examples/security-reviewer-ts run start --",
    "migration-agent:ts": "npm --workspace @cursor-examples/migration-agent-ts run start --",
    "sre-agent:ts": "npm --workspace @cursor-examples/sre-agent-ts run start --",
    "slack-bot:ts": "npm --workspace @cursor-examples/slack-bot-ts run start --",
    "slack-bot:serve": "npm --workspace @cursor-examples/slack-bot-ts run serve",
    "spec-drafter:ts": "npm --workspace @cursor-examples/spec-drafter-ts run start --",
    "codebase-explainer:ts": "npm --workspace @cursor-examples/codebase-explainer-ts run start --",
    "duplicate-ticket-detector:ts": "npm --workspace @cursor-examples/duplicate-ticket-detector-ts run start --",
    "adr-writer:ts": "npm --workspace @cursor-examples/adr-writer-ts run start --",
    "scaffolding-agent:ts": "npm --workspace @cursor-examples/scaffolding-agent-ts run start --",
    "dependency-updater:ts": "npm --workspace @cursor-examples/dependency-updater-ts run start --",
    "type-error-explainer:ts": "npm --workspace @cursor-examples/type-error-explainer-ts run start --",
    "db-migration-drafter:ts": "npm --workspace @cursor-examples/db-migration-drafter-ts run start --",
    "pr-summarizer:ts": "npm --workspace @cursor-examples/pr-summarizer-ts run start --",
    "risk-classifier:ts": "npm --workspace @cursor-examples/risk-classifier-ts run start --",
    "secret-scanner-gate:ts": "npm --workspace @cursor-examples/secret-scanner-gate-ts run start --",
    "test-presence-gate:ts": "npm --workspace @cursor-examples/test-presence-gate-ts run start --",
    "test-coverage-agent:ts": "npm --workspace @cursor-examples/test-coverage-agent-ts run start --",
    "eval-trace-grader:ts": "npm --workspace @cursor-examples/eval-trace-grader-ts run start --",
    "flake-hunter:ts": "npm --workspace @cursor-examples/flake-hunter-ts run start --",
    "release-notes-drafter:ts": "npm --workspace @cursor-examples/release-notes-drafter-ts run start --",
    "feature-flag-reaper:ts": "npm --workspace @cursor-examples/feature-flag-reaper-ts run start --",
    "alert-triage-bot:ts": "npm --workspace @cursor-examples/alert-triage-bot-ts run start --",
    "postmortem-drafter:ts": "npm --workspace @cursor-examples/postmortem-drafter-ts run start --",
    "cost-auditor:ts": "npm --workspace @cursor-examples/cost-auditor-ts run start --"
  },
  "workspaces": [
    "examples/*/ts",
    "eval"
  ],
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
