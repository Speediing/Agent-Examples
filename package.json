{
  "name": "cursor-sdk-agent-examples",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "description": "TypeScript-first Cursor SDK agent examples with Python ports.",
  "type": "module",
  "scripts": {
    "migrate:python-ports": "pnpm --filter @cursor-examples/migration-agent-ts exec node dist/index.js",
    "build": "pnpm -r run build",
    "typecheck": "tsc --noEmit --project tsconfig.eval.json && pnpm -r run build",
    "test": "vitest run --config vitest.tier0.config.ts",
    "test:llm": "vitest run --config vitest.config.ts eval/tier1 eval/tier2 eval/parity/ts-python-trace.test.ts",
    "test:all": "pnpm run test && pnpm run test:llm",
    "hello-world:ts": "pnpm --filter @cursor-examples/hello-world-ts exec node dist/index.js",
    "migration-agent:ts": "pnpm --filter @cursor-examples/migration-agent-ts exec node dist/index.js",
    "tool-calling:ts": "pnpm --filter @cursor-examples/tool-calling-agent-ts exec node dist/index.js",
    "accessibility-agent:ts": "pnpm --filter @cursor-examples/accessibility-agent-ts exec node dist/index.js",
    "sre-agent:ts": "pnpm --filter @cursor-examples/sre-agent-ts exec node dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
